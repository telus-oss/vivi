FROM node:22-bookworm-slim

# Work around Hash Sum mismatch errors caused by CDN/proxy caching inconsistencies
RUN echo 'Acquire::http::Pipeline-Depth "0";' > /etc/apt/apt.conf.d/99fixhash \
    && echo 'Acquire::http::No-Cache "True";' >> /etc/apt/apt.conf.d/99fixhash \
    && echo 'Acquire::BrokenProxy "true";' >> /etc/apt/apt.conf.d/99fixhash

RUN apt-get update && apt-get install -y --no-install-recommends \
    # Core utilities
    curl wget git jq ripgrep ca-certificates less file tree \
    # Process & system monitoring
    procps lsof htop strace \
    # Networking
    iputils-ping iproute2 dnsutils net-tools traceroute netcat-openbsd openssh-client rsync \
    # Editors
    vim nano \
    # Build essentials (many projects need make/gcc for native deps)
    build-essential \
    # Archive tools
    zip unzip tar gzip bzip2 xz-utils \
    # Python (for scripting, many tools depend on it)
    python3 python3-pip python3-venv \
    # Man pages
    man-db \
    # Misc utilities
    sudo tmux patch diffutils \
    && rm -rf /var/lib/apt/lists/*

# Install GitHub CLI
RUN apt-get update && apt-get install -y --no-install-recommends gnupg \
    && curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
    | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg \
    && chmod go+r /usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
    | tee /etc/apt/sources.list.d/github-cli.list > /dev/null \
    && apt-get update && apt-get install -y --no-install-recommends gh \
    && rm -rf /var/lib/apt/lists/*

# Install gh wrapper — intercepts `gh pr create` for Vivi approval flow
# Real gh stays at /usr/bin/gh-real, wrapper goes to /usr/local/bin/gh (shadows it)
RUN mv /usr/bin/gh /usr/bin/gh-real
COPY docker/gh-wrapper.sh /usr/local/bin/gh
RUN chmod +x /usr/local/bin/gh

# Install open-port helper — lets sandbox request port forwarding from the host
COPY docker/open-port.sh /usr/local/bin/open-port
RUN chmod +x /usr/local/bin/open-port

# Install request-secret helper — lets sandbox request API secrets from the user
COPY docker/request-secret.sh /usr/local/bin/request-secret
RUN chmod +x /usr/local/bin/request-secret

# Install open-git helper — starts git daemon for direct push/pull to sandbox
COPY docker/open-git.sh /usr/local/bin/open-git
RUN chmod +x /usr/local/bin/open-git

# Create non-root user (before Claude install so native installer goes to agent's home)
RUN useradd -m -s /bin/bash agent \
    && echo 'agent ALL=(ALL) NOPASSWD:ALL' > /etc/sudoers.d/agent

# Install Claude Code CLI
# Prefer native installer (supports self-update at runtime); fall back to npm if blocked by proxy
# TODO: figure out how to pin a specific version with the native installer
RUN echo ">>> Attempting Claude CLI install via native installer..." \
    && su - agent -c 'curl -fsSL https://claude.ai/install.sh | bash' \
    && echo ">>> Native installer succeeded" \
    || echo ">>> Native installer failed, will fall back to npm"
RUN if which claude > /dev/null 2>&1; then \
      echo ">>> Claude CLI installed via native installer"; \
    else \
      echo ">>> Native installer failed, installing Claude CLI via npm..." \
      && npm install -g @anthropic-ai/claude-code@2.1.81; \
    fi \
    && claude --version
ENV PATH="/home/agent/.local/bin:$PATH"

# Claude config: accept tos, allow dangerously-skip-permissions
RUN mkdir -p /home/agent/.claude && \
    echo '{"hasCompletedOnboarding": true, "acceptedTos": true, "preferredModel": "claude-opus-4-6"}' > /home/agent/.claude.json && \
    chown -R agent:agent /home/agent/.claude /home/agent/.claude.json

RUN apt-get update && apt-get install -y --no-install-recommends gosu socat && rm -rf /var/lib/apt/lists/*

# Install code-server (browser-hosted VS Code) for the in-sandbox editor tab.
ARG CODE_SERVER_VERSION=4.96.4
RUN curl -fsSL https://code-server.dev/install.sh \
      | sh -s -- --version "${CODE_SERVER_VERSION}" \
    && code-server --version

# Install Docker CLI (connects to per-session dind socket proxy at /var/run/docker.sock)
RUN install -m 0755 -d /etc/apt/keyrings \
    && curl -fsSL https://download.docker.com/linux/debian/gpg -o /etc/apt/keyrings/docker.asc \
    && chmod a+r /etc/apt/keyrings/docker.asc \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.asc] https://download.docker.com/linux/debian $(. /etc/os-release && echo "$VERSION_CODENAME") stable" \
       > /etc/apt/sources.list.d/docker.list \
    && apt-get update && apt-get install -y --no-install-recommends docker-ce-cli docker-compose-plugin \
    && rm -rf /var/lib/apt/lists/*

# Create the drop-in entrypoint directory
RUN mkdir -p /docker-entrypoint.d

# Sandbox CLAUDE.md template — rendered into the agent's user-level Claude
# config at runtime so it's outside the user's workspace and never shows up
# in `git status`/`git diff`.
COPY docker/sandbox-CLAUDE.md /opt/vivi/sandbox-CLAUDE.md

# Move base setup into the drop-in directory
COPY docker/entrypoint-init/00-base-setup.sh /docker-entrypoint.d/
RUN chmod +x /docker-entrypoint.d/00-base-setup.sh

# Start code-server on container boot and register its port with the host
COPY docker/entrypoint-init/10-code-server.sh /docker-entrypoint.d/
RUN chmod +x /docker-entrypoint.d/10-code-server.sh

# Entrypoint loops over drop-ins
COPY docker/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

WORKDIR /workspace

ENTRYPOINT ["/entrypoint.sh"]
CMD ["sleep", "infinity"]
